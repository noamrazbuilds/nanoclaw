# LiteLLM Proxy Environment Variables
# Copy to .env and fill in your keys.

# Required: master key for LiteLLM proxy authentication (must start with sk-)
LITELLM_MASTER_KEY=sk-change-me

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenAI API key (get from platform.openai.com)
OPENAI_API_KEY=

# Google AI API key (get from aistudio.google.com) — optional
# GOOGLE_API_KEY=
